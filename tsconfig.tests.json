{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./tests/dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/game/**/*.ts",
    "src/store/**/*.ts",
    "src/utils/**/*.ts",
    "src/types/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/dist"
  ]
}
